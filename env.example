# ============================================
# AI Gigaschool - Переменные окружения
# ============================================
# Скопируйте этот файл в .env и заполните своими значениями
# cp env.example .env
# или на Windows: copy env.example .env

# ============================================
# LLM Провайдер (Model API)
# ============================================

# Выберите провайдер LLM: yandex, openai, openrouter, anthropic, google, mistral
LLM_PROVIDER=yandex

# --- Yandex Cloud (по умолчанию) ---
YANDEX_CLOUD_FOLDER=your_yandex_folder_id
YANDEX_CLOUD_API_KEY=your_yandex_api_key

# --- OpenAI (если LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=your_openai_api_key

# --- OpenRouter (если LLM_PROVIDER=openrouter) ---
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-app-url.example
# OPENROUTER_X_TITLE=AI-Gigaschool

# --- Anthropic/Claude (если LLM_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Google/Gemini (если LLM_PROVIDER=google) ---
# GOOGLE_API_KEY=your_google_api_key

# --- Mistral (если LLM_PROVIDER=mistral или RAG_EMBEDDING_PROVIDER=mistral) ---
# MISTRAL_API_KEY=your_mistral_api_key

# ============================================
# RAG / FAISS (микросервис vector_store; Core и model ходят по HTTP)
# ============================================
# Docker Compose: http://vector-store:8030; локально: http://localhost:8030
# VECTOR_STORE_SERVICE_URL=http://localhost:8030

# Провайдер эмбеддингов: yandex | openai | google | mistral (как в model/llm_adapter).
# Если пусто — совпадает с LLM_PROVIDER. Anthropic для эмбеддингов не поддерживается.
# RAG_EMBEDDING_PROVIDER=yandex

# --- Yandex Embeddings (RAG_YANDEX_*; пустые поля = дефолты LangChain) ---
# RAG_YANDEX_EMBEDDING_QUERY_MODEL=text-search-query
# RAG_YANDEX_EMBEDDING_DOC_MODEL=text-search-doc
# RAG_YANDEX_EMBEDDING_MODEL_VERSION=latest

# --- OpenAI / Google / Mistral: модель эмбеддингов (ключи см. выше) ---
# RAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# RAG_GOOGLE_EMBEDDING_MODEL=models/text-embedding-004
# RAG_MISTRAL_EMBEDDING_MODEL=mistral-embed

# Каталоги индексов: по умолчанию data/profession/profession_vector/<slug>/ и data/education/education_vector/<slug>/
# FAISS_PROFESSION_VECTOR_ROOT=data/profession/profession_vector
# FAISS_COURSES_VECTOR_ROOT=data/education/education_vector
# Полный путь к индексу без подкаталога провайдера (перекрывает *_VECTOR_ROOT):
# FAISS_PROFESSION_INDEX_DIR=
# FAISS_COURSES_INDEX_DIR=

# Исходные JSON для пересборки индексов (по умолчанию пути внутри data/):
# FAISS_PROFESSION_SOURCE_JSON=data/profession/summary_hh_professions_comparison.json
# FAISS_EDUCATION_SOURCE_JSON=data/education/education_comparison.json

# POST /v1/admin/rebuild-faiss-indexes — заголовок Authorization: Bearer <секрет>
# CORE_REBUILD_FAISS_SECRET=change_me_long_random

# ============================================
# Telegram Bot
# ============================================
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# URL Core API (оркестрация, LangGraph). Эндпоинты совместимы со старыми путями /start_talk/ и т.д.
# Docker Compose (хост): http://localhost:8000
# Внутри compose сеть бота: http://core:8020
LLM_BASE_URL=http://localhost:8000

# Локальная отладка без Docker (если сервисы подняты по отдельности):
# CRUD_SERVICE_URL=http://localhost:8010
# LLM_SERVICE_URL=http://localhost:8001

# CRUD: провайдер для пути /users/{id}/session (по умолчанию telegram)
# DEFAULT_IDENTITY_PROVIDER=telegram

# Core: уровень логов (DEBUG, INFO, WARNING). Логи — в stdout контейнера / терминала uvicorn.
# CORE_LOG_LEVEL=INFO

# Core: пошаговый тест v2 и кнопки профессий в одном ответе (v1 — отдельный ход без списка).
# TEST_RUN_VERSION=v2

# ============================================
# HeadHunter API (для парсеров)
# ============================================
# Опционально, если используете парсеры HH
# HH_CLIENT_ID=your_hh_client_id
# HH_CLIENT_SECRET=your_hh_client_secret
# HH_REDIRECT_URI=your_hh_redirect_uri


